{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/somachak/claude-code-skills-db/blob/main/skills-schema.json",
  "title": "Claude Code Skills Database",
  "description": "Schema for skills-database.json. Follows https://code.claude.com/docs/en/skills.",
  "type": "object",
  "required": ["version", "skills"],
  "properties": {
    "version": {
      "type": "string",
      "description": "ISO date of last change, e.g. 2026-04-14."
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp of the last generator run."
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/Skill" }
    }
  },
  "$defs": {
    "Skill": {
      "type": "object",
      "required": [
        "name",
        "title",
        "category",
        "audience",
        "priority",
        "description",
        "trigger_phrases",
        "skill_body"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "maxLength": 64,
          "description": "Lowercase kebab-case. Becomes the /slash-command."
        },
        "title": { "type": "string" },
        "category": {
          "type": "string",
          "enum": [
            "frontend",
            "backend",
            "data",
            "testing",
            "platform",
            "security-reliability",
            "ai-productivity"
          ]
        },
        "audience": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "priority": {
          "type": "string",
          "enum": ["core", "supporting", "experimental"]
        },
        "stage": {
          "type": "string",
          "enum": ["experiment", "build", "harden", "launch", "scale"],
          "description": "The primary project phase where this skill earns its keep. experiment=pre-commitment design/spec; build=active feature construction; harden=pre-ship security and coverage; launch=CI/CD, release, observability; scale=post-launch performance and infra."
        },
        "description": {
          "type": "string",
          "maxLength": 1024,
          "description": "What the skill does and when to use it. Front-loads the key use case; capped at 1,024 chars to stay under the 1,536-char combined cap even with when_to_use."
        },
        "trigger_phrases": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        },
        "skill_body": {
          "type": "string",
          "minLength": 400,
          "description": "The actual markdown body of SKILL.md. Real decision frameworks, checklists, anti-patterns, and worked examples. NOT generic Claude-already-knows instructions."
        },
        "frontmatter_overrides": {
          "type": "object",
          "description": "Additional YAML frontmatter fields (when_to_use, allowed-tools, paths, disable-model-invocation, effort, context, agent, etc.).",
          "additionalProperties": true
        },
        "supporting_files": {
          "type": "object",
          "description": "Map of relative path -> real file content. Empty content is rejected by the generator.",
          "additionalProperties": { "type": "string", "minLength": 40 }
        },
        "provenance": {
          "type": "object",
          "description": "Where the skill body came from. Used by the daily hunter for diff/merge decisions. Not rendered into SKILL.md.",
          "properties": {
            "source_url": { "type": "string" },
            "source_type": {
              "type": "string",
              "enum": ["official-docs", "github-repo", "x-post", "blog", "hand-authored", "daily-hunter"]
            },
            "stars": { "type": "integer", "minimum": 0 },
            "forks": { "type": "integer", "minimum": 0 },
            "captured_at": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    }
  }
}
